@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix fm:    <https://w3id.org/fair-mind/ap#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix snomed: <http://snomed.info/id/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .

# =====================================================
# FAIR-MIND AP v4 — SHACL Validation Shapes
# 7 shapes for downstream data validation
# =====================================================

# S1 — VariableShape: every AP variable must have label, layer, status
fm:VariableShape a sh:NodeShape ;
    sh:targetClass fm:Variable ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:message "Every variable must have rdfs:label" ;
    ] ;
    sh:property [
        sh:path fm:belongsToLayer ;
        sh:minCount 1 ;
        sh:message "Every variable must be assigned to a layer" ;
    ] ;
    sh:property [
        sh:path fm:pipelineStatus ;
        sh:minCount 1 ;
        sh:in ( "implemented" "not_computable" "planned" ) ;
        sh:message "pipelineStatus must be: implemented, not_computable, or planned" ;
    ] .

# S2 — ComputedVariableShape: derived variables need source + params
fm:ComputedVariableShape a sh:NodeShape ;
    sh:targetClass fm:ComputedVariable ;
    sh:property [
        sh:path fm:computedFrom ;
        sh:minCount 1 ;
        sh:class fm:SignalSource ;
        sh:message "ComputedVariable must specify computedFrom (SignalSource)" ;
    ] ;
    sh:property [
        sh:path fm:hasParamsRef ;
        sh:minCount 1 ;
        sh:message "ComputedVariable must reference parameter documentation" ;
    ] .

# S3 — ClinicalVarShape: clinical variables should have external type
fm:ClinicalVarShape a sh:NodeShape ;
    sh:targetClass fm:ClinicalVar ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
    ] ;
    sh:sparql [
        sh:message "ClinicalVar should have a direct external type (e.g., snomed:) or rdfs:seeAlso" ;
        sh:select """
            SELECT $this WHERE {
                $this a fm:ClinicalVar .
                FILTER NOT EXISTS {
                    $this a ?extType .
                    FILTER(
                        CONTAINS(STR(?extType), "snomed.info") ||
                        CONTAINS(STR(?extType), "obolibrary.org")
                    )
                }
                FILTER NOT EXISTS { $this rdfs:seeAlso ?ext . }
            }""" ;
    ] .

# S4 — SpectralHRVShape: frequency-domain variables must specify band
fm:SpectralHRVShape a sh:NodeShape ;
    sh:targetClass fm:SpectralHRV ;
    sh:property [
        sh:path fm:frequencyBand ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "SpectralHRV must specify fm:frequencyBand" ;
    ] .

# S5 — MedicationVarShape: medication variables must reference external vocab
fm:MedicationVarShape a sh:NodeShape ;
    sh:targetClass fm:MedicationVar ;
    sh:sparql [
        sh:message "MedicationVar should have rdfs:seeAlso or direct type to CHEBI/MeSH" ;
        sh:select """
            SELECT $this WHERE {
                $this a fm:MedicationVar .
                FILTER NOT EXISTS {
                    $this a ?extType .
                    FILTER(
                        CONTAINS(STR(?extType), "CHEBI") ||
                        CONTAINS(STR(?extType), "mesh")
                    )
                }
                FILTER NOT EXISTS {
                    $this rdfs:seeAlso ?ext .
                    FILTER(
                        CONTAINS(STR(?ext), "CHEBI") ||
                        CONTAINS(STR(?ext), "mesh")
                    )
                }
            }""" ;
    ] .

# S6 — ExtensionTermShape: fm-only terms must document gap in rdfs:comment
fm:ExtensionTermShape a sh:NodeShape ;
    sh:targetClass fm:Variable ;
    sh:sparql [
        sh:message "Variables without external type or rdfs:seeAlso must have rdfs:comment documenting the gap" ;
        sh:select """
            SELECT $this WHERE {
                $this a fm:Variable .
                FILTER NOT EXISTS {
                    $this a ?extType .
                    FILTER(!CONTAINS(STR(?extType), "fair-mind"))
                    FILTER(?extType != owl:NamedIndividual)
                }
                FILTER NOT EXISTS { $this rdfs:seeAlso ?ext . }
                FILTER NOT EXISTS { $this rdfs:comment ?c . }
            }""" ;
    ] .

# S7 — LayerAssignmentShape: layer must be one of 4 defined layers
fm:LayerAssignmentShape a sh:NodeShape ;
    sh:targetClass fm:Variable ;
    sh:property [
        sh:path fm:belongsToLayer ;
        sh:in (
            fm:Layer1_Clinical
            fm:Layer2_Biomarkers
            fm:Layer3_Provenance
            fm:Layer4_Medications
        ) ;
        sh:message "belongsToLayer must be one of the 4 defined AP layers" ;
    ] .
